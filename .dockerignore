# Hulation Docker build context exclusions
# This file is copied to the build context root by build-docker.sh.
# The build context is the parent dir (/home/ubuntu/work/), which can
# contain unrelated sibling repos. Allowlist what the Dockerfile
# actually needs (hulation + clickhouse), then exclude the heavy
# subdirs inside those.

# Allowlist: ignore everything by default…
*
# …then re-include only what the Dockerfile ADDs.
!hulation
!clickhouse

# Inside hulation/, drop the heavy/dev-only paths.
hulation/.bin
hulation/.gopath
hulation/.cache
hulation/.external
hulation/.git
hulation/.vscode
hulation/.idea
hulation/.claude
hulation/test
hulation/builder-images
hulation/*.sh
hulation/.env
hulation/.env.*
# Frontend build artefacts. node_modules is regenerated inside the
# ui-build stage from package.json + pnpm-lock.yaml; the build/
# directory ships only via the Dockerfile COPY.
hulation/web/analytics/node_modules
hulation/web/analytics/.svelte-kit
hulation/web/analytics/build
hulation/web/analytics/dist

# Inside clickhouse/, drop git history.
clickhouse/.git
