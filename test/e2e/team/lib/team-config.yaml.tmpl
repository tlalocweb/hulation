# Per-node hula config for the multi-node team e2e suites.
# Substituted via envsubst at bring-up time (see test/e2e/team/lib/run.sh).
#
# Variables:
#   ${NODE_ID}              — hula-east / hula-west / hula-emea
#   ${IS_CH_CONNECTED}      — "true" or "false"
#   ${BOOTSTRAP_MODE}       — "first-of-team" / "join" / "solo"
#   ${TEAM_ID}              — team UUID
#   ${ADMIN_ARGON_HASH}
#   ${JWT_KEY}

admin:
    username: admin
    hash: ${ADMIN_ARGON_HASH}

jwt_key: ${JWT_KEY}
jwt_expiration: "72h"
port: 443

hula_host: ${NODE_ID}.team.internal
hula_ssl:
    cert: /var/hula/team-bundles/${NODE_ID}/cert.pem
    key: /var/hula/team-bundles/${NODE_ID}/key.pem

bad_actors:
    disable: true

dbconfig:
    host: hula-clickhouse
    port: 9000
    user: hula
    pass: hula
    dbname: hula
    retries: 5
    delay_retry: 5

servers:
    # Minimal placeholder server. The team suites don't actually serve
    # site traffic — they only exercise admin RPCs + Membership +
    # /readyz. config.LoadConfig requires at least one server, so we
    # define a synthetic one whose host matches this node.
    - host: ${NODE_ID}.team.internal
      id: team-placeholder
      ssl:
          cert: /var/hula/team-bundles/${NODE_ID}/cert.pem
          key: /var/hula/team-bundles/${NODE_ID}/key.pem

team:
    team_id: ${TEAM_ID}
    node_id: ${NODE_ID}
    node_hostname: ${NODE_ID}.team.internal
    data_dir: /var/hula/data
    bootstrap: ${BOOTSTRAP_MODE}
    bind_addr: 0.0.0.0:443
    advertise_addr: ${NODE_ID}.team.internal:443
    bootstrap_token: "{{env:HULA_TEAM_BOOTSTRAP_TOKEN}}"
    pki:
        ca_cert: /var/hula/team-bundles/ca.pem
        node_cert: /var/hula/team-bundles/${NODE_ID}/cert.pem
        node_key: /var/hula/team-bundles/${NODE_ID}/key.pem
    ch_connected: ${IS_CH_CONNECTED}
    ch_relay_peer: hula-east.team.internal:443
    outbox_path: /var/hula/data/outbox/events.queue
